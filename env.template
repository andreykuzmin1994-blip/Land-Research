# Copy this file to .env and fill in real values.
# .env is gitignored. NEVER paste real credentials into env.template — it is
# tracked by git. Edit ONLY the .env file with your secrets.

# Postgres connection string from Supabase. Use the SESSION pooler endpoint
# (port 5432, IPv4-friendly) — verified during Phase 1 validation to support
# PostGIS extension creation and the DDL in prepare.py. The TRANSACTION pooler
# (port 6543) does NOT support all DDL operations and must not be used here.
# URL-encode special characters in the password (! -> %21, @ -> %40, : -> %3A,
# / -> %2F, ? -> %3F, # -> %23, % -> %25, & -> %26, + -> %2B, space -> %20).
DATABASE_URL=postgresql://postgres.PROJECT_REF:URL_ENCODED_PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres

# Anthropic API key (only required when AI fallback layer is built in Phase 12).
# Leave blank for Phase 1.
ANTHROPIC_API_KEY=
